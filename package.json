{
  "name": "web3-gaming",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules contracts/node_modules frontend/dist backend/dist .turbo frontend/.turbo backend/.turbo contracts/.turbo",
    "dev:frontend": "pnpm --filter @web3-gaming/frontend dev",
    "dev:backend": "pnpm --filter @web3-gaming/backend dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "backend/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "backend/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
