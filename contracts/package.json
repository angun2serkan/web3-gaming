{
  "name": "@web3-gaming/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "test": "anchor test --skip-local-validator",
    "test:localnet": "anchor test",
    "lint": "cargo clippy --all-targets -- -D warnings -A unexpected_cfgs",
    "type-check": "cargo check",
    "clean": "anchor clean",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "idl:generate": "anchor build && cp target/idl/escrow.json ../frontend/src/lib/idl/ && cp target/idl/escrow.json ../backend/src/lib/idl/",
    "validator": "solana-test-validator --reset"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "chai": "^4.4.0",
    "mocha": "^10.7.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0"
  }
}
